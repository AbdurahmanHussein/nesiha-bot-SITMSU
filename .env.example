# Telegram Bot Token (get from @BotFather on Telegram)
BOT_TOKEN=your_bot_token_here

# JWT Secret for Admin Dashboard Authentication
JWT_SECRET=secret_code_value_here

# Neon PostgreSQL Connection String
DATABASE_URL=database_url_value_here

# Admin Telegram User IDs (comma-separated). These users can receive admin notifications.
ADMIN_IDS=admin_id_here_optional

# Port for the Express server (Render sets this automatically)
PORT=3001